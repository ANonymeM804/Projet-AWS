<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sticko - Inscription</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@700&family=DM+Sans:wght@300;400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="../css/signup.css">
 
</head>
<body>

  <nav>
    <ul>
      <li><a href="/">Accueil</a></li>
      <li><a href="/login">LogIn</a></li>
    </ul>
  </nav>

  <main class="page">
    <section class="left">
      <h1>Rejoins <span class="hl">Sticko</span></h1>
      <p>
        Crée ton compte pour commencer à publier tes post-its, organiser tes idées
        et interagir sur le mur collaboratif.
      </p>
    </section>

    <section class="right">
      <div class="signup-card">
        <h2>Inscription</h2>
        <p class="intro">
          Remplis ce formulaire pour créer ton compte.
        </p>

        <div id="message" class="message"></div>

        <form action="/signup" method="POST" id="signupForm">

          <input type="hidden" name="_csrf" value="{{ csrfToken }}"><!--ajouter token -->

          <div class="form-group">
            <label for="username">Nom d'utilisateur</label>
            <input
              type="text"
              id="username"
              name="username"
              placeholder="Ex : abcdef123"
              required
              minlength="3"
              maxlength="30"
            />
          </div>

          <div class="form-group">
            <label for="password">Mot de passe</label>
            <input
              type="password"
              id="password"
              name="password"
              placeholder="Choisis un mot de passe"
              required
              minlength="8"
            />
            <p class="password-hint">8 caractères minimum.</p>
          </div>

          <div class="form-group">
            <label for="confirmPassword">Confirmer le mot de passe</label>
            <input
              type="password"
              id="confirmPassword"
              name="confirmPassword"
              placeholder="Retape ton mot de passe"
              required
              minlength="8"
            />
          </div>

          <button type="submit" class="signup-btn">Créer mon compte</button>
        </form>

        <p class="bottom-link">
          Déjà inscrit ? <a href="/login">Se connecter</a>
        </p>
      </div>
    </section>
  </main>

  <footer>
    <span>© 2026 Sticko — Fait avec 💛 en France</span>
    <span>
      <a href="#">Mentions légales</a> &nbsp;·&nbsp;
      <a href="#">Confidentialité</a> &nbsp;·&nbsp;
      <a href="#">Contact</a>
    </span>
  </footer>
   <script src="../JavaScript/signup.js"></script>
</body>
</html>
