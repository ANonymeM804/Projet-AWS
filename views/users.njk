<!DOCTYPE html>
<html lang="fr">
 <head>
   <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
   <title>Sticko - Post-its </title>
   <link rel="stylesheet" href="../css/users.css">
 </head>

 <body>
    
    <input type="hidden" name="_csrf" value="{{ csrfToken }}"><!--ajouter token -->
    
    <nav>
        <div class="user-info" id="user-info"></div>
        <ul>
            <li><a href="/mur_postits" class="creation" id="creation">Mur Postits</a></li>
            <li><a href=" " class="logout" id="logout">Logout</a></li>
          
        </ul>
    </nav>

    
    
    <div class="mur" id="mur" >
        
      <h1>Gestion des Utilisateurs </h1>
      <table border="1" cellpadding="10" cellspacing="0">
        <thead>
          <tr>
            <th>ID</th>
            <th>Username</th>
            <th>Role</th>
            <th>Droit de Création</th>
            <th>Droit de Modification</th>
            <th>Droit de Suppression</th>
            <th>Date de création</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="usersTableBody">  

          <template id="userRowTemplate">
            <tr>
              <td class="id"></td>
              <td class="username"></td>

              <td>
                <select class="role-select">
                  <option value="user">user</option>
                  <option value="admin">admin</option>
                </select>
              </td>

              <td><input type="checkbox" class="create-checkbox"></td>
              <td><input type="checkbox" class="edit-checkbox"></td>
              <td><input type="checkbox" class="delete-checkbox"></td>

              <td class="created-at"></td>

              <td>
                <div class="actions">
                  <button class="save-btn">💾 Enregistrer</button>
                  <button class="delete-btn">🗑 Supprimer</button>
                </div>
              </td>
            </tr>
          </template>
          </tbody>
      </table>
      
    </div>
    
    
<footer>
  <span>© 2026 Sticko — Fait avec 💛 en France</span>
  <span>
    <a href=" ">Mentions légales</a> &nbsp;·&nbsp;
    <a href=" ">Confidentialité</a> &nbsp;·&nbsp;
    <a href=" ">Contact</a>
  </span>
</footer>

    <script src="../JavaScript/users.js"></script>
</body>
</html>
